{
  "provider_accounts": {
    "openrouter": {
      "api_key": "YOUR_OPENROUTER_KEY",
      "text_model": "deepseek/deepseek-chat",
      "image_model": "google/gemini-3.1-flash-image"
    }
  },
  "host": {
    "provider": "openrouter",
    "model": "deepseek/deepseek-chat",
    "api_base": "https://openrouter.ai/api/v1",
    "proxy": "http://127.0.0.1:7897"
  },
  "image": {
    "provider": "openrouter",
    "use_text_provider": true,
    "model": "google/gemini-3.1-flash-image",
    "api_base": "https://openrouter.ai/api/v1",
    "proxy": "http://127.0.0.1:7897",
    "style_img2img_strength": 0.25,
    "constraints": {
      "size_multiple": null
    }
  },
  "prompt": {
    "model": "deepseek/deepseek-chat",
    "api_base": "https://openrouter.ai/api/v1",
    "proxy": "http://127.0.0.1:7897"
  },
  "code": {
    "model": "deepseek/deepseek-chat"
  },
  "video": {
    "provider": "seedance",
    "api_key": "YOUR_ARK_API_KEY",
    "api_base": "https://ark.cn-beijing.volces.com/api/v3",
    "model": "mini",
    "duration": 4,
    "resolution": "480p",
    "ratio": "1:1",
    "generate_audio": false,
    "watermark": false,
    "ratio_from_reference": "adaptive",
    "split_frames": {
      "frames": 8,
      "trim_lead": true,
      "trim_trail": true,
      "skip_lead_ratio": 0.25,
      "skip_trail_ratio": 0.05
    }
  },
  "matting": {
    "trim": {
      "threshold": 240,
      "padding": 2
    },
    "color_key": {
      "threshold": 235,
      "fuzz": 24,
      "key_scope": "exterior",
      "morph_erode": 2,
      "morph_dilate": 1,
      "despeckle": 1
    },
    "validate_edges": {
      "edge_width": 2,
      "brightness_threshold": 220,
      "max_white_ratio": 0.025,
      "max_semi_transparent": 8
    },
    "video_frames": {
      "engine": "ai",
      "model": "birefnet-general",
      "trim": { "threshold": 200, "padding": 2 },
      "soft_key": {
        "threshold": 200,
        "fuzz": 36,
        "key_scope": "global",
        "morph_erode": 1,
        "morph_dilate": 1,
        "despeckle": 1
      }
    }
  },
  "test": {
    "vision_model": "google/gemini-2.5-flash",
    "api_key": "YOUR_OPENROUTER_KEY",
    "api_base": "https://openrouter.ai/api/v1",
    "proxy": "http://127.0.0.1:7897"
  },
  "godot": {
    "engine_path": "",
    "import_trim_lead": true,
    "import_trim_trail": true,
    "import_skip_lead_ratio": 0.25,
    "import_skip_trail_ratio": 0.05
  },
  "toolchain": {
    "bin_dir": "~/.gamefactory/toolchain/bin"
  },
  "agents": {
    "hermes_provider": "openrouter",
    "executors": {
      "pi": { "provider": "openrouter", "model": null },
      "hermes": { "provider": "openrouter", "yolo": true },
      "codex": {
        "use_third_party": false,
        "provider": null,
        "model": null,
        "sandbox": "workspace-write"
      },
      "cursor": { "permission_mode": "force" }
    },
    "brief": { "executor": "pi", "skill": "host-chat", "provider": "openrouter", "model": null },
    "it": { "executor": "pi", "skill": "diagnose", "provider": "openrouter", "model": null },
    "orchestrator": { "executor": "hermes", "skill": "game-factory-orchestrator", "provider": "openrouter", "model": null },
    "prompt-crafter": { "executor": "hermes", "skill": "game-factory-prompt-crafter" },
    "image-generator": { "executor": "pipeline", "skill": "game-factory-image-generator" },
    "video-generator": { "executor": "pipeline", "skill": "game-factory-video-generator" },
    "godot-assembler": { "executor": "pipeline", "skill": "game-factory-godot-assembler" },
    "godot-developer": { "executor": "codex", "skill": "game-factory-godot-developer", "provider": null, "model": null, "use_third_party": false },
    "tester": { "executor": "hermes", "skill": "game-factory-tester" },
    "instances": {
      "example-it-instance": {
        "role_kind": "it",
        "executor": "pi",
        "provider": "deepseek",
        "model": "deepseek-chat",
        "use_third_party": false
      }
    }
  }
}
